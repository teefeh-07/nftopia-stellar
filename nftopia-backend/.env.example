# Server Configuration
PORT=3000
GRAPHQL_PORT=3001
NODE_ENV=development
GRAPHQL_PLAYGROUND_ENABLED=true
GRAPHQL_INTROSPECTION_ENABLED=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=300

# Database Configuration (Optional for future use)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nftopia

# JWT Configuration
# JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# Stellar/Soroban Configuration
# Horizon URL - must match STELLAR_NETWORK.
# Mainnet: https://horizon.stellar.org
# Testnet: https://horizon-testnet.stellar.org
# Required in production; optional in development/test with network-aware defaults.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=TESTNET
COLLECTION_FACTORY_CONTRACT_ID=CB6UOYI5KLAXLBBALZITFMCR6LIDHW2BQFRB7VXMUWZ6Z2BFTG3UFPM4
TRANSACTION_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TRANSACTION_TIMEOUT_SECONDS=60
# Optional server-side signer for state-changing Soroban transactions.
# STELLAR_OPERATOR_PUBLIC_KEY=G...
# STELLAR_OPERATOR_SECRET=S...
# SOROBAN_EVENT_CONTRACT_IDS=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Decentralized Storage Configuration
IPFS_PROVIDER=pinata
IPFS_GATEWAY_URL=https://ipfs.io/ipfs
IPFS_MAX_FILE_SIZE_BYTES=52428800
IPFS_RETRY_ATTEMPTS=2
IPFS_RETRY_BACKOFF_MS=250
IPFS_PINATA_JWT=
IPFS_WEB3STORAGE_TOKEN=
IPFS_NFTSTORAGE_TOKEN=

ARWEAVE_GATEWAY_URL=https://arweave.net
ARWEAVE_MAX_FILE_SIZE_BYTES=104857600
ARWEAVE_HOST=arweave.net
ARWEAVE_PORT=443
ARWEAVE_PROTOCOL=https
ARWEAVE_RETRY_ATTEMPTS=2
ARWEAVE_RETRY_BACKOFF_MS=350
ARWEAVE_WALLET_PATH=
ARWEAVE_WALLET_JWK=

STORAGE_FALLBACK_ENABLED=true

# Meilisearch Configuration
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev-search-key

# Marketplace Settlement Smart Contract
MARKETPLACE_SETTLEMENT_CONTRACT_ID=CB7QBOUQ3YRBOTGZ32RNKQIBGIBL4EQRIQUYV4KEMIDVJ5IRQV57IXSK
CONTRACT_TRANSACTION_TIMEOUT=60
ENABLE_ONCHAIN_SETTLEMENT=true